# Postgres. Local-only deploy (post-2026-06-04): Postgres 17 via Postgres.app
# on 127.0.0.1:5433, db gc_curriculum, launchd com.gc.postgres.
DATABASE_URL=postgresql://admin@127.0.0.1:5433/gc_curriculum

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5.4

# AI provider — 'openai' (default), 'anthropic', or 'local'
AI_PROVIDER=openai

# Anthropic (optional, only if switching)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Local / omlx (OpenAI-compatible). Used when AI_PROVIDER=local.
# This is the Phase 2 hybrid-deploy path — see
# docs/superpowers/plans/2026-05-25-phase2-hybrid-deploy.md
LOCAL_BASE_URL=http://localhost:8000/v1
LOCAL_API_KEY=
LOCAL_MODEL=gemma-4-26B-A4B-it-QAT-MLX-4bit
# Vision registry (lib/ai/vision-models.ts) — per-task local omlx vision model +
# soft-token budget. Budgets need the PATCHED omlx (mlx-vlm #1426 + omlx #1986,
# the resolution knob — see ~/.dev-ports.yaml). Defaults are the 2026-06-23 bench
# winners; these envs override them.
#   docTranscribe: image-PDF OCR in "use local" mode → gemma-26B-A4B @ 1120
LOCAL_VISION_MODEL=gemma-4-26B-A4B-it-QAT-MLX-4bit
LOCAL_VISION_BUDGET=1120
#   slideNote: middle-tier describeSlide notes → gemma-12B @ 560
SLIDE_VISION_MODEL=gemma-4-12B-it-qat-4bit
SLIDE_VISION_BUDGET=560

# Optional OFFLOAD for the LOCAL vision paths — image-PDF OCR (transcribeDocument)
# AND slide description (describeSlide). When set, those requests go to this
# OpenAI-compatible endpoint (e.g. a DGX Spark serving Gemma-4-26B-A4B-NVFP4 over
# SGLang) and FALL BACK to the local omlx model on any failure (two-phase — see
# lib/ai/vision-offload.ts). Architecture: local omlx = real-time voice; DGX = all
# vision. The endpoint MUST be a real vision deployment — verified 2026-07-02 the
# DGX 26B on :30001 reads fine print to 7px AND honors response_format json_object
# (its 12B on :30000 is text-only, so don't point at that). Offload requests are
# STANDARD OpenAI (no omlx-only vision_soft_tokens_per_image / chat_template_kwargs).
# Unset → local only.
VISION_OFFLOAD_BASE_URL=
VISION_OFFLOAD_MODEL=
VISION_OFFLOAD_API_KEY=
# Concurrency for the OFFLOAD path ONLY (SGLang continuous-batches → the volume win:
# ~100+ docs/min at 16 vs local's ~30/min ceiling). Local/fallback stays low (OCR 2,
# slides 4) — memory-bound + voice-shared, so a DGX outage can't fan this at the box.
# Default 12.
VISION_OFFLOAD_CONCURRENCY=
# Only shunt jobs of at least this many items (pages/slides) to the DGX; smaller
# ones stay on the local omlx — small/quick tasks are fast locally and clear
# before they tie up the box v2v needs, while time-consuming jobs go to the DGX.
# Default 4 (matches the measured per-doc latency crossover). 1 = always offload.
VISION_OFFLOAD_MIN_ITEMS=

# Campus-hosted LLMs (Clemson RCD, OpenAI-compatible). Used when
# AI_PROVIDER=campus, OR by the embeddings client regardless of which
# generation provider is selected. Default model qwen3.6-35b-a3b-fp8 — MoE
# with 3B active params, ~180 tok/s on the shared cluster, the right
# speed/quality balance for hot-path digest/contextualize/chat calls.
# Heavier options (glm-5.1-fp8 at ~4 tok/s, deepseek-v4-pro at ~15 tok/s
# with 1M ctx) are available via per-call model override when reasoning
# depth justifies the latency — see https://llm.rcd.clemson.edu/v1/models.
# Embeddings use qwen3-embedding-4b (2560-dim) at the same base URL.
CAMPUS_LLM_BASE_URL=https://llm.rcd.clemson.edu/v1
CAMPUS_LLM_API_KEY=
CAMPUS_LLM_DEFAULT_MODEL=qwen3.6-35b-a3b-fp8

# Audio transcription (mic capture). Local mlx-whisper/omlx is the default and
# keeps audio on-box (FERPA: class discussion can contain identifiable student
# voices). The OpenAI Whisper API is used ONLY when WHISPER_BACKEND=openai
# (explicit always-external), or when the local binary is missing AND
# WHISPER_OPENAI_FALLBACK=1. With the fallback unset, a missing binary fails
# loudly rather than silently shipping audio off-box.
WHISPER_BACKEND=
WHISPER_OPENAI_FALLBACK=

# PDF extractor — 'unpdf' (in-process fallback) or 'docling' (local
# docling-serve HTTP, much better tables + figure descriptions). The local
# deploy runs docling.
PDF_PARSER=docling
DOCLING_URL=http://localhost:5001

# Optional: enable Docling's VLM-based picture description (Phase 2 hybrid
# only — requires docling-serve started with
# DOCLING_SERVE_ALLOW_CUSTOM_PICTURE_DESCRIPTION_CONFIG=true and
# DOCLING_SERVE_ENABLE_REMOTE_SERVICES=true). Points at any OpenAI-
# compatible chat-completions endpoint; defaults to local omlx.
DOCLING_VLM_ENABLED=
DOCLING_VLM_URL=http://localhost:8000/v1/chat/completions
DOCLING_VLM_API_KEY=
# docPicture: Docling embedded-chart/diagram captioning → gemma-12B (light; was
# the heavyweight 35B, dropped 2026-06-23 — captions don't need it). Vision registry.
DOCLING_VLM_MODEL=gemma-4-12B-it-qat-4bit
DOCLING_VLM_PROMPT=

# Faculty Basic Auth (Phase 2 stopgap — see plan doc). Format: user:password.
# When set, faculty routes (/capture, /explore, /program, /admin, /settings)
# require HTTP Basic Auth. When unset, no auth gate is added.
FACULTY_BASIC_AUTH=

# Create-only faculty credential (two-tier auth, 2026-06-13). Format: user:password.
# When set, this credential may ADD a single course (/courses/new + the single-add
# roster API) but is forbidden (403) on every edit surface. When unset, only
# FACULTY_BASIC_AUTH exists (today's single-tier behavior). Shares the same Basic
# realm as FACULTY_BASIC_AUTH.
CREATE_ONLY_AUTH=

# Wiki MCP server (/api/mcp) — shared bearer token for agents that query the
# curriculum wiki over MCP Streamable HTTP. Generate: `openssl rand -hex 32`.
# Agents send `Authorization: Bearer <token>`. FAIL-CLOSED: if unset, /api/mcp
# rejects every request (the endpoint is never open). Do NOT put an inline
# `# comment` after the value (dotenv keeps it as part of the value).
WIKI_MCP_TOKEN=

# Unguessable URL slug for the prototype
PROTOTYPE_SLUG=preview-abc123def456

# Faculty capture-flow links (Edit, "+ Add a course") use a graceful voice→typed
# fallback (components/CaptureLink.tsx): on click they probe VOICE_ORIGIN with a
# short timeout and, if reachable, navigate there (mic works over HTTPS); else
# they navigate to FALLBACK_ORIGIN (reliable direct URL, typed only). This gives
# ON-CAMPUS faculty automatic "funnel-until-it-isn't, then typed" behavior;
# off-campus is out of scope (FALLBACK_ORIGIN is firewalled to them).
# NEXT_PUBLIC_ → inlined into the client bundle at BUILD time (rebuild to change;
# these are public URLs, not secrets). Both unset → plain same-origin links (no
# probe). No trailing slash.
#   VOICE_ORIGIN: HTTPS origin that supports the mic — the Tailscale Funnel today
#     (https://admins-mac-studio-2.tailb723c1.ts.net); swap to the official
#     gcworkflow.clemson.edu HTTPS once IT provisions it.
#   FALLBACK_ORIGIN: reliable direct on-campus URL (typed) — http://gcworkflow.clemson.edu:3000
NEXT_PUBLIC_VOICE_ORIGIN=
NEXT_PUBLIC_FALLBACK_ORIGIN=

# Admin-route second factor (the `/api/admin/*` routes, behind faculty Basic
# Auth). Routes accept `Authorization: Bearer <ADMIN_TOKEN>` OR the slug (in the
# header or, legacy, in `?slug=`/body). OPTIONAL: when unset, the slug carried in
# the Authorization header still authenticates, so admin clients can move the
# secret out of the query string without provisioning a new token. Set a
# distinct value (e.g. `openssl rand -hex 32`) once you want admin auth rotatable
# independently of PROTOTYPE_SLUG. Same no-inline-`# comment` rule as above.
ADMIN_TOKEN=

# In-app feedback widget — Phase 1 intake.
# Set both to enable. When unset, /api/feedback returns 503.
# GITHUB_TOKEN: PAT (classic or fine-grained) with repo scope on the target repo.
# GITHUB_FEEDBACK_REPO: "owner/repo" — where issues are created (typically the same repo).
GITHUB_TOKEN=
GITHUB_FEEDBACK_REPO=

# Cost protection
DAILY_COST_CAP_USD=5
COST_ALERT_EMAIL=chiptoe@mac.com

# Shared Google Sheet that backs the `courses` table (anyone-with-link viewable).
# The admin Resync endpoint reads it via the unauthenticated gviz CSV export.
GOOGLE_SHEET_ID=12aPhgrIlhDYjKD0-Gt97glf1d9fKtwKmL4FwM8iTz7Q

# Base URL used in partner magic-link URLs (no trailing slash). The partner
# survey is served by the Mac via the Tailscale Funnel since the 2026-06-04
# Vercel/Resend teardown; faculty hand-copy the links from /admin/partners.
PARTNERS_BASE_URL=https://admins-mac-studio-2.tailb723c1.ts.net

# Demand → coverage sufficiency seam (Q1). When "1", the per-target synthesis
# page shows the read-only sufficiency panel (employer-weighted demand vs
# curriculum attainment). OFF by default — requires migration 0032
# (career_target_demand) to be applied first. Build-ahead; not activated.
DEMAND_COVERAGE_SEAM=

# Synthesis re-run threshold — when current submission count exceeds the
# cached run's submissionCount by this many or more, the per-target page
# shows "needs re-run" and the re-run button is highlighted.
SYNTHESIS_STALENESS_THRESHOLD=5

# CourseCapture v2 ingestion pipeline. When set to "1", finalizeExtraction
# runs the new digest + chunk + embed + index path on every material; when
# unset, the legacy reference-compression-only path runs. Stage 2a uses
# the in-memory vector store; Stage 2b will swap in Weaviate.
COURSECAPTURE_V2_INGESTION=

# Local Weaviate (multi-tenant vector DB). Installed via Homebrew, managed by
# launchd (~/Library/LaunchAgents/com.weaviate.plist), anonymous access,
# 127.0.0.1 only. Default port 8080 is held by Caddy; Weaviate listens on
# 8090 (HTTP) + 50051 (gRPC). Per-course tenants named `coursecapture-<slug>`
# per the agentic-retrieval spec. Stage 2b will read these.
WEAVIATE_URL=http://127.0.0.1:8090
WEAVIATE_GRPC_URL=127.0.0.1:50051
WEAVIATE_API_KEY=
WEAVIATE_TENANT_PREFIX=coursecapture
