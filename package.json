{
  "name": "curriculum-developer",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prepare": "git config core.hooksPath .githooks || true",
    "dev": "next dev --turbopack",
    "dev:lan": "next dev --turbopack --hostname 0.0.0.0",
    "dev:lan-https": "next dev --turbopack --hostname 0.0.0.0 --experimental-https --experimental-https-key ./certs/localhost+2-key.pem --experimental-https-cert ./certs/localhost+2.pem",
    "build": "next build --turbopack",
    "start": "next start",
    "start:lan": "next start --hostname 0.0.0.0",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx scripts/seed-career-targets.ts",
    "db:seed-courses": "tsx scripts/seed-catalog-courses.ts",
    "wiki:lint": "tsx scripts/wiki-lint.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.79",
    "@ai-sdk/openai": "^3.0.65",
    "@ai-sdk/openai-compatible": "^2.0.48",
    "@anthropic-ai/sdk": "^0.97.1",
    "@base-ui/react": "^1.4.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@react-email/components": "^1.0.12",
    "ai": "^6.0.191",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.16.0",
    "mammoth": "^1.12.0",
    "next": "15.5.18",
    "openai": "^6.38.0",
    "papaparse": "^5.5.3",
    "pg": "^8.21.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.7.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "unpdf": "^1.6.2",
    "weaviate-client": "^3.13.0",
    "youtube-transcript": "^1.3.1",
    "zod": "^4.4.3"
